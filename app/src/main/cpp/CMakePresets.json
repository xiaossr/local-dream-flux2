{
  "version": 3,
  "configurePresets": [
    {
      "name": "android-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/android",
      "cacheVariables": {
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-28",
        "ANDROID_STL": "c++_static",
        "CMAKE_SYSTEM_NAME": "Android",
        "ANDROID_NATIVE_API_LEVEL": "28",
        "CMAKE_SYSTEM_VERSION": "28",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK_ROOT}",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "EXECUTORCH_ROOT": "$env{EXECUTORCH_ROOT}"
      },
      "toolchainFile": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
      "environment": {
        "ANDROID_NDK_ROOT": "/Users/xiaog/urop/android-ndk-r28",
        "EXECUTORCH_ROOT": "/Users/xiaog/urop/executorch/cmake-out-android"
      }
    },
    {
      "name": "android-debug",
      "inherits": "android-base",
      "displayName": "Android Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "QNN_DEBUG_ENABLE": "ON"
      }
    },
    {
      "name": "android-release",
      "inherits": "android-base",
      "displayName": "Android Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "QNN_DEBUG_ENABLE": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "android-debug",
      "configurePreset": "android-debug"
    },
    {
      "name": "android-release",
      "configurePreset": "android-release"
    }
  ]
}
